# Backend environment example for PureAir
# Copy to .env and fill values before running in production

PORT=5002
MONGODB_URI=mongodb://127.0.0.1:27017/hospital_aqi
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace_this_with_a_strong_secret
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=
PURPLEAIR_LOCAL_IP=
PROMETHEUS_SCRAPE_TOKEN=
# Set to true to allow unauthenticated metrics scrapes from localhost
PROMETHEUS_ALLOW_LOCAL=true
# ============================================================================
# PUREAIR MONITORING SYSTEM - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# WARNING: Never commit .env files to version control
# Copy this file to .env and configure values for your deployment
# ============================================================================

# Server Configuration
PORT=5002
NODE_ENV=development  # Set to 'production' for production deployment

# ============================================================================
# DATABASE CONFIGURATION (Production Required)
# ============================================================================
# Local Development (no authentication):
# MONGODB_URI=mongodb://127.0.0.1:27017/hospital_aqi
#
# Production (with authentication):
# MONGODB_URI=mongodb://username:STRONG_PASSWORD@host:27017/hospital_aqi?authSource=admin
# ============================================================================
MONGODB_URI=mongodb://127.0.0.1:27017/hospital_aqi

# ============================================================================
# SECURITY CREDENTIALS (REQUIRED FOR PRODUCTION)
# ============================================================================
# Generate strong JWT secret (64 characters minimum):
#   Linux/Mac: openssl rand -hex 64
#   Windows (PowerShell): [System.Convert]::ToBase64String((1..64|%{[byte](Get-Random -Maximum 256)}))
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_64_CHARACTER_SECRET_GENERATED_FROM_COMMAND_ABOVE

# MQTT Broker Security (change for production)
MQTT_PORT=1886
MQTT_USERNAME=hospital_node
# Generate with: openssl rand -hex 32
MQTT_PASSWORD=REPLACE_WITH_STRONG_RANDOM_MQTT_PASSWORD

# ============================================================================
# EMAIL CONFIGURATION (Required for password reset)
# ============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ============================================================================
# FRONTEND & CORS CONFIGURATION
# ============================================================================
# Development:
FRONTEND_URL=http://localhost:5173
#
# Production Example:
# FRONTEND_URL=https://your-domain.com
# ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# ============================================================================
# PURPLEAIR INTEGRATION
# ============================================================================
# Local Network Polling
PURPLEAIR_LOCAL_IP=
PURPLEAIR_POLL_INTERVAL=30
PURPLEAIR_NODE_ID=PurpleAir-PA-II
PURPLEAIR_ROOM_ID=PurpleAir-Zone

# Webhook API Key Security
# Generate with: openssl rand -hex 32
PURPLEAIR_API_KEY=REPLACE_WITH_STRONG_RANDOM_PURPLEAIR_API_KEY

# ============================================================================
# SECURITY ENHANCEMENTS
# ============================================================================
# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # per window per IP

# Session Security
SESSION_TIMEOUT_MINUTES=60
JWT_EXPIRY_HOURS=24

# HTTPS/TLS Configuration (for production proxy)
# Set to true if behind HTTPS proxy (nginx, cloudflare, etc.)
BEHIND_HTTPS_PROXY=false

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
# Database backup directory (relative to backend/)
BACKUP_DIR=./backups
BACKUP_CRON_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
